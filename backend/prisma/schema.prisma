// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  name         String?
  email        String?  @unique
  passwordHash String?
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  chats        Chat[]
  avatarMemories AvatarMemoryProfile[]
  memoryProfile UserMemoryProfile?
  persona      Persona?
}

model Avatar {
  id          String   @id @default(uuid())
  name        String
  personality String
  createdAt   DateTime @default(now())

  avatarMemories AvatarMemoryProfile[]
  chats       Chat[]
}

model Chat {
  id        String   @id @default(uuid())
  userId    String
  avatarId  String
  message   String
  response  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  avatar Avatar @relation(fields: [avatarId], references: [id])
}

model Persona {
  id        String   @id @default(uuid())
  userId    String   @unique
  summary   String
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model UserMemoryProfile {
  id                   String   @id @default(uuid())
  userId               String   @unique
  curatedAvatarReady   Boolean  @default(false)
  curatedAvatarName    String?
  curatedAvatarTitle   String?
  curatedAvatarImage   String?
  curatedAccentFrom    String?
  curatedAccentTo      String?
  profileSummary       String
  personalityCore      String
  emotionalMaturity    String
  communicationStyle   String
  preferenceProfile    Json
  emotionalProfile     Json
  supportNeeds         Json
  recurringThemes      Json
  notableFacts         Json
  sourceChatCount      Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model AvatarMemoryProfile {
  id                  String   @id @default(uuid())
  userId              String
  avatarId            String
  avatarName          String
  summary             String
  relationshipDynamic String
  communicationNotes  String
  emotionalContext    Json
  recurringTopics     Json
  notableFacts        Json
  interactionCount    Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  avatar Avatar @relation(fields: [avatarId], references: [id])

  @@unique([userId, avatarId])
}
